# Keep pnpm-lock.yaml + pnpm-workspace.yaml — EAS needs them for install.
# Include all workspace packages referenced by the lockfile (artifacts/* + lib/*).

.pnpm-store
.local
.cache
.codex
.cursor
.vs
.tmp_*
.tmp_combined*
**/*.err.log
eval-summary.json
tsconfig.zip
lib/db/drizzle/batches

lib/e2e

.env
.env.local
.env.*.local

node_modules

# Web-only assets and unrelated workspace apps (mobile build does not use these).
attached_assets
artifacts/vndrly
artifacts/api-server
artifacts/vndrly-commercial
artifacts/mockup-sandbox
artifacts/vndrly-mobile/.expo-smoke-export

# Leftover export archives and design sources — never needed on EAS.
**/*.zip
**/*.psd
