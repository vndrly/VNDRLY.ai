# Copy to `.env.local` and fill in the password from your Supabase project settings.
# VNDRLY uses ONE Postgres database — Supabase — for local dev and production.
#
# Dashboard: https://supabase.com/dashboard/project/bihjmgbdzbhcnsuhzzwo

SUPABASE_PROJECT_REF=bihjmgbdzbhcnsuhzzwo
SUPABASE_URL=https://bihjmgbdzbhcnsuhzzwo.supabase.co

# Direct connection — Replit Secrets / Linux / macOS with IPv6
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.bihjmgbdzbhcnsuhzzwo.supabase.co:5432/postgres

# Windows desktop dev — transaction pooler on port 6543 (host is often aws-1-us-west-2)
DATABASE_URL=postgresql://postgres.bihjmgbdzbhcnsuhzzwo:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# Local desktop dev (web + api-server)
PORT=8080
BASE_PATH=/
VITE_API_PROXY_TARGET=http://localhost:8080
SESSION_SECRET=local-dev-session-secret-change-in-production

# Assistant — set real values for Ask V / signup assistant features
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# iOS / Expo — API base URL (mobile does NOT connect to Postgres directly)
EXPO_PUBLIC_DOMAIN=https://vndrly.ai

# One-time optional — browser deploy uses REPLIT_PASSWORD if set
# REPLIT_EMAIL=v@vndrly.ai
# REPLIT_PASSWORD=
# PRODUCTION_HEALTH_URL=https://vndrly.ai/api/healthz
