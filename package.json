{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs'); for (const f of ['package-lock.json','yarn.lock']) fs.rmSync(f,{force:true}); const ua=process.env.npm_config_user_agent||''; const execPath=process.env.npm_execpath||''; if (!/^pnpm\\//.test(ua) && !/pnpm/i.test(execPath)) { console.error('Use pnpm instead'); process.exit(1); }\"",
    "dev:bootstrap": "bash scripts/dev-bootstrap.sh",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "pnpm run test:libs && pnpm run test:web && pnpm run test:mobile && pnpm run test:api && pnpm run test:e2e",
    "test:libs": "pnpm -r --filter \"./lib/**\" --filter \"!@workspace/e2e\" --if-present run test",
    "test:web": "pnpm --filter @workspace/vndrly run test",
    "test:mobile": "pnpm --filter @workspace/vndrly-mobile run test",
    "test:api": "pnpm --filter @workspace/api-server run test",
    "test:e2e": "pnpm --filter @workspace/e2e exec playwright test",
    "lint:i18n": "pnpm --filter @workspace/scripts run lint:i18n",
    "swap:logo": "node scripts/swap-vndrly-logo.mjs",
    "ship it": "powershell -ExecutionPolicy Bypass -File scripts/ship-it.ps1",
    "save": "powershell -ExecutionPolicy Bypass -File scripts/ship-it.ps1",
    "publish:online": "powershell -ExecutionPolicy Bypass -File scripts/publish-online.ps1",
    "dev:local": "powershell -ExecutionPolicy Bypass -File scripts/ensure-local-dev.ps1 -RefreshApi -OpenBrowser",
    "wake": "powershell -ExecutionPolicy Bypass -File scripts/ensure-local-dev.ps1 -RefreshApi -OpenBrowser",
    "dev:watch": "powershell -NoExit -ExecutionPolicy Bypass -File scripts/keep-dev-awake.ps1",
    "dev:autostart:install": "powershell -ExecutionPolicy Bypass -File scripts/install-local-dev-autostart.ps1",
    "dev:autostart:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-local-dev-autostart.ps1",
    "testflight:submit": "powershell -ExecutionPolicy Bypass -File scripts/submit-testflight.ps1 -NonInteractive",
    "testflight:build": "powershell -ExecutionPolicy Bypass -File scripts/testflight-build.ps1 -NonInteractive",
    "ios:sim:eas": "powershell -ExecutionPolicy Bypass -File scripts/ios-simulator-eas.ps1 -NonInteractive",
    "ios:sim:local": "powershell -ExecutionPolicy Bypass -File scripts/ios-simulator-local.ps1",
    "ios:sim:install": "powershell -ExecutionPolicy Bypass -File scripts/ios-simulator-install.ps1",
    "setup:vps": "node lib/e2e/scripts/godaddy-setup-vps.mjs",
    "setup:production": "node scripts/godaddy-provision.mjs",
    "deploy:production": "node scripts/godaddy-deploy.mjs",
    "preflight:deploy": "node scripts/preflight-deploy.mjs",
    "pack:machine-transfer": "powershell -ExecutionPolicy Bypass -File scripts/create-machine-transfer-pack.ps1",
    "check:live": "node scripts/check-live.mjs",
    "check:vps": "node scripts/check-vps-api.mjs",
    "setup:majik": "node scripts/setup-majik.mjs",
    "build:majik": "pnpm --filter @workspace/majik-desktop run tauri:build",
    "tauri:build": "pnpm --filter @workspace/majik-desktop run tauri:build"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "ssh2": "^1.17.0",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.21"
  }
}
